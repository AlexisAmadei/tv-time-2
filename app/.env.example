# Expo client environment (TEMPLATE, tracked in git).
#
# Copy to app/.env (untracked) and fill in the values. Only EXPO_PUBLIC_* vars
# are exposed to client code.
#
# The URL is the Kong gateway. The anon key must be the ANON_KEY from
# supabase/.env (they are the same key) — see supabase/README.md.

EXPO_PUBLIC_SUPABASE_URL=http://localhost:8000
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...paste-the-ANON_KEY-from-supabase/.env...
