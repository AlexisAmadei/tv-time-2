# popcorn-time — self-hosted Supabase environment (TEMPLATE, tracked in git)
#
# Copy this to `supabase/.env` and fill in the SECRET values, OR just run:
#   node scripts/generate-keys.mjs
# which writes a ready-to-use supabase/.env with a fresh, internally consistent
# secret set (see supabase/README.md).
#
# The real supabase/.env is gitignored — never commit it.
#
# ⚠️ The three secret values below are cryptographically linked:
#   ANON_KEY and SERVICE_ROLE_KEY MUST be HS256 JWTs signed with JWT_SECRET.
# Copying keys from another project (or inventing random strings) makes every
# Kong-routed request 401 even though `docker compose ps` shows every container
# "Up". Always generate the trio together — that is what generate-keys.mjs does.

############
# Secrets — REGENERATE, do not ship these placeholder values
############

# Postgres superuser password.
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# Symmetric HS256 signing secret (>= 32 chars). Signs ANON_KEY/SERVICE_ROLE_KEY.
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# HS256 JWTs signed with JWT_SECRET. Claims: { role, iss:"supabase", iat, exp }.
ANON_KEY=eyJ...replace-me...
SERVICE_ROLE_KEY=eyJ...replace-me...

# Kong dashboard basic-auth (route unused in this trimmed stack, but referenced).
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-me

# Storage S3-protocol endpoint credentials.
S3_PROTOCOL_ACCESS_KEY_ID=replace-me-hex-16
S3_PROTOCOL_ACCESS_KEY_SECRET=replace-me-hex-32

############
# Database
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# API gateway (Kong)
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# URLs — Kong gateway is the single public entrypoint (localhost:8000)
############
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

############
# Auth (GoTrue). v1 = email/password + magic link only (no OAuth).
############
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
# Email confirmation. Defaults to `false` — the PRODUCTION-safe posture: users
# must confirm their email before they can sign in. This template ships the safe
# value so copying it to a real deployment never accidentally accepts unverified
# sign-ups. For a frictionless LOCAL dev loop, set this to `true` in your own
# (gitignored) supabase/.env so email/password sign-up returns a JWT session
# immediately, with no confirmation round-trip. Either way, magic-link/OTP
# sign-in still sends a real email — captured locally by Inbucket.
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# Local mail catcher: the `supabase-mail` (Inbucket) service in docker-compose.
# Captures confirmation + magic-link/OTP emails — read them at http://localhost:9000.
# SMTP_USER/SMTP_PASS are intentionally EMPTY: Inbucket needs no auth, and GoTrue
# refuses to send credentials over Inbucket's unencrypted SMTP ("unencrypted
# connection" 500). Leave them blank locally; set real creds only with real SMTP.
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Popcorn Time
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############
# REST (PostgREST)
############
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Storage
############
GLOBAL_S3_BUCKET=stub
STORAGE_TENANT_ID=stub
REGION=stub

############
# Edge Functions
############
FUNCTIONS_VERIFY_JWT=false
